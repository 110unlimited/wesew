---
const navLinks = [
  { href: "/", label: "Головна" },
  { href: "/services", label: "Послуги" },
  { href: "/contacts", label: "Контакти" },
];
const currentPath = Astro.url.pathname;
---

<header class="bg-bg-white/80 backdrop-blur-sm sticky top-0 z-50 border-b border-border">
  <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="shrink-0">
      <img src="/logo.jpg" alt="WeSeW — ательє індивідуального пошиву" class="h-16 md:h-20 w-auto" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium tracking-wide uppercase transition-colors duration-200",
              currentPath === link.href
                ? "text-primary"
                : "text-text-muted hover:text-primary",
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href="tel:+380963061920"
      class="hidden md:inline-flex items-center gap-2 bg-primary text-white px-5 py-2.5 text-sm font-semibold tracking-wide uppercase rounded-sm transition-colors duration-200 hover:bg-primary/90 cursor-pointer"
    >
      Зателефонувати
    </a>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 cursor-pointer"
      aria-label="Відкрити меню"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-border bg-bg-white">
    <ul class="flex flex-col px-4 py-4 gap-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "block text-sm font-medium tracking-wide uppercase",
              currentPath === link.href
                ? "text-primary"
                : "text-text-muted",
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="tel:+380963061920"
          class="block text-center bg-primary text-white px-5 py-3 text-sm font-semibold tracking-wide uppercase rounded-sm"
        >
          Зателефонувати
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
