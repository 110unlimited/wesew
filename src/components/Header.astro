---
const navLinks = [
  { href: "/", label: "Головна" },
  { href: "/services", label: "Послуги" },
  { href: "/contacts", label: "Контакти" },
];
const currentPath = Astro.url.pathname;
---

<header class="bg-bg-white/80 backdrop-blur-sm sticky top-0 z-50 border-b border-border">
  <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="shrink-0 flex items-center gap-3">
      <img src="/logo.jpg" alt="WeSeW — ательє індивідуального пошиву" class="h-12 md:h-16 w-auto" />
      <span class="font-heading text-2xl md:text-3xl font-bold tracking-tight text-primary">WeSeW</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium tracking-wide uppercase transition-colors duration-200",
              currentPath === link.href
                ? "text-primary"
                : "text-text-muted hover:text-primary",
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href="tel:+380963061920"
      class="hidden md:inline-flex items-center gap-2 text-primary font-semibold tracking-wide transition-colors duration-200 hover:text-primary/80 cursor-pointer"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      +380 96 306 19 20
    </a>

    <!-- Mobile: phone icon + burger -->
    <div class="md:hidden flex items-center gap-3">
      <a href="tel:+380963061920" class="p-2 text-primary cursor-pointer" aria-label="Зателефонувати">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
      </a>
      <button
        id="mobile-menu-btn"
        class="p-2 cursor-pointer"
        aria-label="Відкрити меню"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-border bg-bg-white">
    <ul class="flex flex-col px-4 py-4 gap-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "block text-sm font-medium tracking-wide uppercase",
              currentPath === link.href
                ? "text-primary"
                : "text-text-muted",
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
