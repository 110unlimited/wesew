---
import Layout from "../layouts/Layout.astro";
---

<Layout title="WeSeW — Ательє індивідуального пошиву у Харкові">
  <!-- Hero -->
  <section class="relative bg-bg-white">
    <div class="max-w-6xl mx-auto px-4 py-20 md:py-32 text-center">
      <p class="text-sm font-semibold tracking-widest uppercase text-primary-light mb-4">
        25+ років досвіду
      </p>
      <h1 class="font-heading text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-text leading-tight">
        Ми шиємо<br />
        <span class="text-primary">вашу історію</span>
      </h1>
      <p class="mt-6 text-lg md:text-xl text-text-muted max-w-2xl mx-auto leading-relaxed">
        Ательє Ірини Ємельянової у Харкові. Персональний пошив, весільні сукні, ремонт та перешив одягу.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="tel:+380963061920"
          class="w-full sm:w-auto bg-primary text-white px-8 py-4 text-sm font-semibold tracking-wide uppercase rounded-sm transition-colors duration-200 hover:bg-primary/90 cursor-pointer"
        >
          Зателефонувати
        </a>
        <a
          href="https://t.me/+380963061920"
          target="_blank"
          rel="noopener noreferrer"
          class="w-full sm:w-auto border-2 border-primary text-primary px-8 py-4 text-sm font-semibold tracking-wide uppercase rounded-sm transition-colors duration-200 hover:bg-primary hover:text-white cursor-pointer"
        >
          Написати в Telegram
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-text">
          Про ательє
        </h2>
        <p class="mt-6 text-text-muted leading-relaxed text-lg">
          Ательє WeSeW — це понад 25 років бездоганної роботи. Ірина Ємельянова створює одяг, який підкреслює індивідуальність кожного клієнта. Від ідеї до готового виробу — з увагою до кожної деталі.
        </p>
      </div>

      <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-8 bg-bg-white rounded-sm border border-border">
          <p class="font-heading text-5xl font-bold text-primary">25+</p>
          <p class="mt-2 text-sm text-text-muted uppercase tracking-wide">років досвіду</p>
        </div>
        <div class="text-center p-8 bg-bg-white rounded-sm border border-border">
          <p class="font-heading text-5xl font-bold text-primary">1000+</p>
          <p class="mt-2 text-sm text-text-muted uppercase tracking-wide">задоволених клієнтів</p>
        </div>
        <div class="text-center p-8 bg-bg-white rounded-sm border border-border">
          <p class="font-heading text-5xl font-bold text-primary">100%</p>
          <p class="mt-2 text-sm text-text-muted uppercase tracking-wide">індивідуальний підхід</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services preview -->
  <section class="py-16 md:py-24 bg-bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center">
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-text">
          Послуги
        </h2>
        <p class="mt-4 text-text-muted text-lg">
          Повний спектр послуг з пошиву та ремонту одягу
        </p>
      </div>

      <!-- Bento grid — minimal, no photos -->
      <div class="mt-12 grid grid-cols-1 md:grid-cols-12 gap-4">
        <a href="/services/custom-tailoring" class="group md:col-span-12 p-8 md:p-10 border border-border rounded-sm hover:border-primary/30 transition-all duration-200 cursor-pointer bg-bg flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div>
            <p class="text-primary-light text-xs font-semibold tracking-widest uppercase">від 2 000 грн</p>
            <h3 class="font-heading text-2xl md:text-4xl font-bold text-text mt-1">Персональний пошив</h3>
            <p class="text-text-muted text-sm mt-2">Чоловічий та жіночий одяг за індивідуальними мірками</p>
          </div>
          <span class="text-primary text-sm font-semibold tracking-wide uppercase shrink-0 opacity-0 group-hover:opacity-100 transition-opacity duration-200">Детальніше &rarr;</span>
        </a>

        <a href="/services/wedding-dresses" class="group md:col-span-6 p-8 border border-border rounded-sm hover:border-primary/30 transition-all duration-200 cursor-pointer bg-bg">
          <p class="text-primary-light text-xs font-semibold tracking-widest uppercase">від 8 000 грн</p>
          <h3 class="font-heading text-2xl md:text-3xl font-bold text-text mt-1">Весільні сукні</h3>
          <p class="text-text-muted text-sm mt-2">Від ескізу до останнього стібка</p>
          <span class="mt-4 inline-block text-primary text-sm font-semibold tracking-wide uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-200">Детальніше &rarr;</span>
        </a>

        <a href="/services/wedding-suits" class="group md:col-span-6 p-8 border border-border rounded-sm hover:border-primary/30 transition-all duration-200 cursor-pointer bg-bg">
          <p class="text-primary-light text-xs font-semibold tracking-widest uppercase">від 6 000 грн</p>
          <h3 class="font-heading text-2xl md:text-3xl font-bold text-text mt-1">Весільні костюми</h3>
          <p class="text-text-muted text-sm mt-2">Елегантний костюм для нареченого</p>
          <span class="mt-4 inline-block text-primary text-sm font-semibold tracking-wide uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-200">Детальніше &rarr;</span>
        </a>

        <a href="/services/prom" class="group md:col-span-4 p-6 border border-border rounded-sm hover:border-primary/30 transition-all duration-200 cursor-pointer bg-bg">
          <p class="text-primary-light text-xs font-semibold tracking-widest uppercase">від 3 000 грн</p>
          <h3 class="font-heading text-xl md:text-2xl font-bold text-text mt-1">Випускні костюми та сукні</h3>
          <span class="mt-3 inline-block text-primary text-sm font-semibold tracking-wide uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-200">Детальніше &rarr;</span>
        </a>

        <a href="/services/repairs" class="group md:col-span-4 p-6 border border-border rounded-sm hover:border-primary/30 transition-all duration-200 cursor-pointer bg-bg">
          <p class="text-primary-light text-xs font-semibold tracking-widest uppercase">від 200 грн</p>
          <h3 class="font-heading text-xl md:text-2xl font-bold text-text mt-1">Ремонт одягу</h3>
          <span class="mt-3 inline-block text-primary text-sm font-semibold tracking-wide uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-200">Детальніше &rarr;</span>
        </a>

        <a href="/services/alterations" class="group md:col-span-4 p-6 border border-border rounded-sm hover:border-primary/30 transition-all duration-200 cursor-pointer bg-bg">
          <p class="text-primary-light text-xs font-semibold tracking-widest uppercase">від 500 грн</p>
          <h3 class="font-heading text-xl md:text-2xl font-bold text-text mt-1">Перешив</h3>
          <span class="mt-3 inline-block text-primary text-sm font-semibold tracking-wide uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-200">Детальніше &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-heading text-4xl md:text-5xl font-bold text-text">
        Готові створити щось особливе?
      </h2>
      <p class="mt-4 text-text-muted text-lg">
        Зв'яжіться з нами — обговоримо вашу ідею
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="tel:+380963061920"
          class="w-full sm:w-auto bg-primary text-white px-8 py-4 text-sm font-semibold tracking-wide uppercase rounded-sm transition-colors duration-200 hover:bg-primary/90 cursor-pointer"
        >
          Зателефонувати
        </a>
        <a
          href="https://t.me/+380963061920"
          target="_blank"
          rel="noopener noreferrer"
          class="w-full sm:w-auto border-2 border-primary text-primary px-8 py-4 text-sm font-semibold tracking-wide uppercase rounded-sm transition-colors duration-200 hover:bg-primary hover:text-white cursor-pointer"
        >
          Telegram
        </a>
      </div>
    </div>
  </section>
</Layout>
