---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Контакти — WeSeW Ательє у Харкові"
  description="Контакти ательє WeSeW: адреса, телефон, графік роботи. вул. Валентинівська, 12, Харків. Пн-Сб 09:00-18:00."
>
  <section class="py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="font-heading text-4xl md:text-6xl font-bold text-text">
          Контакти
        </h1>
        <p class="mt-4 text-text-muted text-lg">
          Зв'яжіться з нами або завітайте до ательє
        </p>
      </div>

      <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Contact info -->
        <div class="space-y-8">
          <div>
            <h2 class="font-heading text-2xl font-semibold text-text mb-4">Зв'язатися</h2>
            <ul class="space-y-4">
              <li>
                <a
                  href="tel:+380963061920"
                  class="flex items-center gap-3 text-lg text-text hover:text-primary transition-colors duration-200"
                >
                  <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  +380 96 306 19 20
                </a>
              </li>
              <li>
                <a
                  href="https://t.me/+380963061920"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 text-lg text-text hover:text-primary transition-colors duration-200"
                >
                  <svg class="w-5 h-5 text-primary shrink-0" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.446 1.394c-.14.18-.357.295-.6.295l.213-3.053 5.56-5.023c.24-.213-.054-.334-.373-.121l-6.869 4.326-2.96-.924c-.64-.203-.658-.64.135-.954l11.566-4.458c.538-.196 1.006.128.828.94z" />
                  </svg>
                  Telegram
                </a>
              </li>
              <li>
                <a
                  href="mailto:wesew@gmail.com"
                  class="flex items-center gap-3 text-lg text-text hover:text-primary transition-colors duration-200"
                >
                  <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  wesew@gmail.com
                </a>
              </li>
            </ul>
          </div>

          <div>
            <h2 class="font-heading text-2xl font-semibold text-text mb-4">Адреса</h2>
            <a
              href="https://maps.app.goo.gl/5mnVHBy7YPqm3HfB9"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-start gap-3 text-lg text-text hover:text-primary transition-colors duration-200"
            >
              <svg class="w-5 h-5 text-primary shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              вул. Валентинівська, 12, Харків, 61000
            </a>
          </div>

          <div>
            <h2 class="font-heading text-2xl font-semibold text-text mb-4">Графік роботи</h2>
            <ul class="space-y-2">
              <li class="flex items-center gap-3 text-lg">
                <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <span class="text-text">Пн — Сб:</span>
                  <span class="text-text-muted ml-2">09:00–18:00</span>
                </div>
              </li>
              <li class="flex items-center gap-3 text-lg">
                <svg class="w-5 h-5 text-text-muted shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <span class="text-text">Нд:</span>
                  <span class="text-text-muted ml-2">Вихідний</span>
                </div>
              </li>
            </ul>
          </div>
        </div>

        <!-- Map -->
        <div class="aspect-square md:aspect-auto rounded-sm overflow-hidden border border-border">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2563.6590660679753!2d36.3255256!3d50.0177451!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4127a7ddbdfba465%3A0x2ae3f2a1768d7878!2z0JDRgtC10LvRjNC1IFdlU2VX!5e0!3m2!1sen!2sua!4v1773585698200!5m2!1sen!2sua"
            class="w-full h-full min-h-80"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Розташування ательє WeSeW на карті"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</Layout>
